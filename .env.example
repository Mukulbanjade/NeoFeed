# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Reddit
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=NeoFeed/1.0

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_TO=your-email@example.com

# Auth — bcrypt hash of the numeric PIN users type in the app (header X-Pin).
# Expected PIN for local/demo parity with NeoFeedFrontend: 1234 (never commit a real production hash).
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'1234', bcrypt.gensalt()).decode())"
PIN_HASH=

# App
SCRAPE_INTERVAL_MINUTES=30
DIGEST_HOURS=8,20

# CORS: "*" (default) or comma-separated frontend URLs, e.g. https://app.vercel.app,https://yourdomain.com
CORS_ORIGINS=*
